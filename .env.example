# Watchtower production configuration (copy to .env and adjust)

# --- Database ---
WATCHTOWER_DATABASE_PATH=/data/watchtower.db
WATCHTOWER_BACKUP_DIR=/backups

# --- Tenant / mode ---
WATCHTOWER_DEFAULT_TENANT_SLUG=default
WATCHTOWER_DEFAULT_MODE=learn

# --- Ingest sources (defaults for onboarding) ---
WATCHTOWER_SERVER_STACK_LOGS_ROOT=/lab/server-stack/logs
WATCHTOWER_INGEST_DEFAULT_LIMIT=500
WATCHTOWER_ELASTICSEARCH_URL=
WATCHTOWER_WAZUH_API_URL=

# --- LLM provider chain (comma-separated fallback order) ---
WATCHTOWER_LLM_PROVIDER_CHAIN=openai,anthropic,gemini,ollama,custom_openai_compatible
WATCHTOWER_LLM_MAX_RETRIES=2
WATCHTOWER_OPENAI_API_KEY=
WATCHTOWER_OPENAI_MODEL=gpt-4o-mini
WATCHTOWER_ANTHROPIC_API_KEY=
WATCHTOWER_ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
WATCHTOWER_GEMINI_API_KEY=
WATCHTOWER_GEMINI_MODEL=gemini-2.0-flash
WATCHTOWER_OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
WATCHTOWER_OLLAMA_MODEL=llama3.2
WATCHTOWER_CUSTOM_OPENAI_BASE_URL=
WATCHTOWER_CUSTOM_OPENAI_API_KEY=
WATCHTOWER_CUSTOM_OPENAI_MODEL=default

# --- Baseline ---
WATCHTOWER_BASELINE_LEARNING_WINDOW_DAYS=45
WATCHTOWER_BASELINE_MIN_USER_SAMPLES=5

# --- Retention (days, 0 = disabled) ---
WATCHTOWER_RETENTION_RAW_EVENTS_DAYS=90
WATCHTOWER_RETENTION_NORMALIZED_EVENTS_DAYS=180
WATCHTOWER_RETENTION_AUDIT_DAYS=365
WATCHTOWER_RETENTION_LLM_AUDIT_DAYS=90

# --- Daemon / health ---
WATCHTOWER_DAEMON_INGEST_INTERVAL_SECONDS=60
WATCHTOWER_HEALTH_LISTEN_HOST=127.0.0.1
WATCHTOWER_HEALTH_LISTEN_PORT=8080
WATCHTOWER_AUDIT_LOG_ENABLED=true
